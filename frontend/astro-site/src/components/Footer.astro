<footer
  style="border-top: 1px solid var(--color-border); margin-top: 8rem; padding: 2.5rem 0;"
>
  <div
    class="max-w-6xl mx-auto px-8 flex flex-col md:flex-row items-center justify-between gap-4"
  >
    <span
      style="font-family: var(--font-mono); font-size: 0.6875rem; color: var(--color-muted); letter-spacing: 0.06em;"
    >
      © 2025 Lucas Calbó — Madrid, Spain
    </span>

    <span
      style="font-family: var(--font-mono); font-size: 0.6875rem; color: var(--color-muted); letter-spacing: 0.06em;"
    >
      Built with Astro · Deployed on AWS
    </span>

    <a
      href="mailto:lucascalbo@gmail.com"
      style="font-family: var(--font-mono); font-size: 0.6875rem; color: var(--color-muted); text-decoration: none; letter-spacing: 0.06em; transition: color 0.15s;"
      onmouseover="this.style.color='var(--color-accent)'"
      onmouseout="this.style.color='var(--color-muted)'"
    >
      lucascalbo@gmail.com
    </a>
  </div>
</footer>
