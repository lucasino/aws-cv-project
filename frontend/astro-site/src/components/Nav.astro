---
const navLinks = [
  { href: "/#experience", label: "Experience" },
  { href: "/#projects", label: "Projects" },
  { href: "/#skills", label: "Skills" },
  { href: "/cv", label: "CV" },
];

const currentPath = Astro.url.pathname;
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-6xl mx-auto px-6">
    <nav class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div
          class="w-8 h-8 rounded border border-accent flex items-center justify-center
                    group-hover:bg-accent transition-colors duration-200"
        >
          <span
            class="font-display text-accent text-sm group-hover:text-bg transition-colors duration-200"
            >LC</span
          >
        </div>
        <span class="font-mono text-sm text-muted hidden sm:block"
          >lucas.calbo</span
        >
      </a>

      <!-- Links -->
      <ul class="hidden md:flex items-center gap-1">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="font-mono text-xs uppercase tracking-widest px-4 py-2 rounded
                     text-muted hover:text-text hover:bg-panel transition-all duration-200"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- CTA -->
      <a href="/cv" class="btn-primary text-xs">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-3.5 h-3.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"
          ></path>
        </svg>
        Download CV
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-muted hover:text-text"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-surface border-t border-border px-6 py-4"
  >
    <ul class="flex flex-col gap-2">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="font-mono text-sm text-muted hover:text-accent block py-2 transition-colors"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  // Solid nav on scroll
  const nav = document.getElementById("nav");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      nav?.classList.add(
        "bg-bg/95",
        "backdrop-blur-md",
        "border-b",
        "border-border",
      );
    } else {
      nav?.classList.remove(
        "bg-bg/95",
        "backdrop-blur-md",
        "border-b",
        "border-border",
      );
    }
  });

  // Mobile menu toggle
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => menu?.classList.toggle("hidden"));
</script>
