---

<!-- Anti-flash script: runs before paint, reads saved preference -->
<script is:inline>
  (function () {
    const saved = localStorage.getItem("theme");
    const prefersDark = window.matchMedia(
      "(prefers-color-scheme: dark)",
    ).matches;
    if (saved === "dark" || (!saved && prefersDark)) {
      document.documentElement.classList.add("dark");
    }
  })();
</script>

<header
  id="nav"
  style="
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 50;
  background: color-mix(in srgb, var(--color-bg) 90%, transparent);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--color-border);
  transition: background 0.25s ease, border-color 0.25s ease;
"
>
  <div style="max-width: 72rem; margin: 0 auto; padding: 0 2rem;">
    <nav
      style="display: flex; align-items: center; justify-content: space-between; height: 3.5rem;"
    >
      <!-- Identity -->
      <a
        href="/"
        style="text-decoration: none; display: flex; align-items: center; gap: 1rem;"
      >
        <span
          style="font-family: var(--font-display); font-size: 1.125rem; color: var(--color-ink); letter-spacing: -0.01em; transition: color 0.25s;"
        >
          Lucas Calbó
        </span>
        <span
          style="width: 1px; height: 1rem; background: var(--color-border-strong);"
        ></span>
        <span
          style="font-family: var(--font-mono); font-size: 0.6875rem; color: var(--color-muted); letter-spacing: 0.08em; text-transform: uppercase; transition: color 0.25s;"
        >
          Software Engineer
        </span>
      </a>

      <!-- Right side -->
      <div style="display: flex; align-items: center; gap: 0.5rem;">
        <!-- Nav links (desktop) -->
        <ul
          style="display: none; align-items: center; list-style: none; margin: 0; padding: 0;"
          class="md-flex"
        >
          {
            [
              { href: "/#experience", label: "Experience" },
              { href: "/#skills", label: "Skills" },
              { href: "/#aws", label: "Architecture" },
              { href: "/cv", label: "CV" },
            ].map((link) => (
              <li>
                <a
                  href={link.href}
                  class="nav-link"
                  style="
                font-family: var(--font-body);
                font-size: 0.8125rem;
                color: var(--color-muted);
                text-decoration: none;
                padding: 0 1rem;
                height: 3.5rem;
                display: flex;
                align-items: center;
                transition: color 0.15s;
              "
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>

        <!-- Theme toggle -->
        <button
          id="theme-toggle"
          class="theme-toggle"
          aria-label="Toggle theme"
          title="Toggle light / dark"
        >
          <!-- Sun (shown in dark mode) -->
          <svg
            id="icon-sun"
            xmlns="http://www.w3.org/2000/svg"
            width="15"
            height="15"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            style="display:none;"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 3v2m0 14v2M4.22 4.22l1.42 1.42m12.72 12.72 1.42 1.42M3 12H1m22 0h-2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42M12 7a5 5 0 100 10A5 5 0 0012 7z"
            ></path>
          </svg>
          <!-- Moon (shown in light mode) -->
          <svg
            id="icon-moon"
            xmlns="http://www.w3.org/2000/svg"
            width="15"
            height="15"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z"></path>
          </svg>
        </button>

        <!-- CTA (desktop) -->
        <a
          href="mailto:lucascalbo@gmail.com"
          class="btn-primary md-inline-flex"
          style="padding: 0.5rem 1.25rem; font-size: 0.75rem; display: none;"
        >
          Get in touch
        </a>

        <!-- Mobile menu button -->
        <button
          id="menu-btn"
          style="
          background: none; border: none; cursor: pointer;
          padding: 0.375rem; color: var(--color-ink-2);
          display: flex; align-items: center;
        "
          class="md-hidden"
          aria-label="Open menu"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    style="
    display: none;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 2rem 1.5rem;
    transition: background 0.25s;
  "
  >
    {
      [
        { href: "/#experience", label: "Experience" },
        { href: "/#skills", label: "Skills" },
        { href: "/#aws", label: "Architecture" },
        { href: "/cv", label: "CV" },
        { href: "mailto:lucascalbo@gmail.com", label: "Get in touch" },
      ].map((link) => (
        <a
          href={link.href}
          style="
        display: block;
        font-family: var(--font-body);
        font-size: 0.875rem;
        color: var(--color-ink-2);
        text-decoration: none;
        padding: 0.625rem 0;
        border-bottom: 1px solid var(--color-border);
        transition: color 0.15s;
      "
        >
          {link.label}
        </a>
      ))
    }
  </div>
</header>

<!-- Responsive helpers (pure CSS, no Tailwind needed) -->
<style>
  @media (min-width: 768px) {
    .md-flex {
      display: flex !important;
    }
    .md-inline-flex {
      display: inline-flex !important;
    }
    .md-hidden {
      display: none !important;
    }
  }

  .nav-link:hover {
    color: var(--color-ink) !important;
  }
</style>

<script>
  // ── Theme toggle logic ──
  const toggle = document.getElementById("theme-toggle");
  const iconSun = document.getElementById("icon-sun");
  const iconMoon = document.getElementById("icon-moon");
  const html = document.documentElement;

  function applyTheme(dark: boolean) {
    if (dark) {
      html.classList.add("dark");
      iconSun!.style.display = "block";
      iconMoon!.style.display = "none";
    } else {
      html.classList.remove("dark");
      iconSun!.style.display = "none";
      iconMoon!.style.display = "block";
    }
  }

  // Set icon on load
  applyTheme(html.classList.contains("dark"));

  // Toggle on click
  toggle?.addEventListener("click", () => {
    const isDark = !html.classList.contains("dark");
    applyTheme(isDark);
    localStorage.setItem("theme", isDark ? "dark" : "light");
  });

  // ── Mobile menu ──
  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const open = menu!.style.display === "block";
    menu!.style.display = open ? "none" : "block";
  });
</script>
